# Learning Loop - environment variables template
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored. Never commit real keys.

# ─────────────────────────────────────────────────────────────
# Supabase
# Project Settings → API in Supabase dashboard
# ─────────────────────────────────────────────────────────────

# Public Project URL — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key — safe to expose to the browser, RLS protects data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Bypasses RLS.
# Never import this into client components or expose in browser bundles.
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# Anthropic (Claude API)
# https://console.anthropic.com/settings/keys
# ─────────────────────────────────────────────────────────────

# Server-only. Used for Haiku 4.5 and Sonnet 4.6 calls.
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────
# Voyage AI (embeddings)
# https://dash.voyageai.com/api-keys
# ─────────────────────────────────────────────────────────────

# Server-only. Used for voyage-3 embeddings (1024 dims).
VOYAGE_API_KEY=

# ─────────────────────────────────────────────────────────────
# App config
# ─────────────────────────────────────────────────────────────

# Base URL of the app — used for Magic Link redirects.
# Local dev: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Cron security
# ─────────────────────────────────────────────────────────────

# Random secret shared between Vercel Cron and the app.
# Generate: openssl rand -hex 32
# Set this same value in Vercel dashboard → Settings → Environment Variables.
# Vercel automatically sends it as `Authorization: Bearer <CRON_SECRET>` on cron calls.
CRON_SECRET=
